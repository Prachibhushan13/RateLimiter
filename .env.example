# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=200

# Rate Limiting Defaults
DEFAULT_ALGORITHM=token_bucket
DEFAULT_LIMIT=100
DEFAULT_WINDOW_SECONDS=60
DEFAULT_TOKEN_CAPACITY=100
DEFAULT_REFILL_RATE=10

# Admin
ADMIN_API_KEY=dev-secret

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3000
